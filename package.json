{
  "name": "scripture-intelligence-server",
  "version": "1.0.0",
  "description": "Advanced MCP server for Bible study with natural language queries, cross-references, and faith-based reasoning",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "bible",
    "scripture",
    "theology",
    "christianity",
    "bible-study",
    "cross-reference",
    "devotional"
  ],
  "author": "Scripture Intelligence Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "compromise": "^14.10.0",
    "fuse.js": "^7.0.0",
    "natural": "^6.5.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.19.39",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
