        },
        {
          "@type": "Question",
          "name": "Which Bible translations are included?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The server bundles complete public-domain World English Bible, King James Version, and American Standard Version text. Copyrighted modern translations require separately licensed data."
          }
        },
        {
          "@type": "Question",
          "name": "Can it help prepare sermons and Bible lessons?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. It includes sermon outlines, sermon research, Bible study guides, lesson plans, discussion questions, quizzes, memory verses, devotionals, prayer points, and reading plans."
