# Scripture Intelligence Server Configuration

# Database path for SQLite database
SCRIPTURE_DB_PATH=./scripture_intelligence.db

# Default Bible translation (ESV, NIV, KJV, etc.)
DEFAULT_TRANSLATION=ESV

# Feature flags
ENABLE_ORIGINAL_LANGUAGES=true
ENABLE_HISTORICAL_CONTEXT=true
ENABLE_THEOLOGICAL_ANALYSIS=true

# Performance settings
CACHE_SIZE=1000

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# Server settings
SERVER_HOST=localhost
SERVER_PORT=3000
